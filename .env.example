# Copy to .env and edit. Never commit a real .env file.

# --- Auth DB ---
AUTH_DB_USER=auth
AUTH_DB_PASSWORD=auth
AUTH_DB_NAME=auth_db

# --- Submission DB ---
SUBMISSION_DB_USER=submission
SUBMISSION_DB_PASSWORD=submission
SUBMISSION_DB_NAME=submission_db

# --- JWT (MUST be identical for both services) ---
JWT_SECRET=please-change-me-to-a-32+char-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRES_MINUTES=60

# --- Admin bootstrap ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin12345

# --- Object storage (MinIO/S3) ---
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=photos
# Endpoint the BROWSER hits when fetching presigned URLs. In dev,
# http://localhost:9000 resolves to the docker-mapped MinIO port. In prod,
# set this to the public hostname of your S3 service (e.g. an AWS S3 region
# endpoint or your MinIO ingress host).
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000

# --- Upload safety ---
MAX_UPLOAD_BYTES=5242880  # 5 MB

# --- CORS (comma-separated; use specific origins in prod) ---
CORS_ORIGINS=*

# --- Frontend build args (URLs baked into the static bundle) ---
VITE_AUTH_API=http://localhost:8001
VITE_SUBMISSION_API=http://localhost:8002
